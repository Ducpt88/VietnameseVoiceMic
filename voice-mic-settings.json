      "replacement": "con app",
      "regex": true
    },
    {
      "pattern": "\\bthích\\s+lại\\b",
      "replacement": "fix lại",
      "regex": true
    },
    {
      "pattern": "\\btối\\s+về\\b",
      "replacement": "tối ưu về",
      "regex": true
